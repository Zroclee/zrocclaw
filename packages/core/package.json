{
  "name": "@zrocclaw/core",
  "private": true,
  "version": "0.0.0",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./playwright": {
      "types": "./src/playwright/index.ts",
      "import": "./dist/playwright.js",
      "require": "./dist/playwright.cjs",
      "default": "./dist/playwright.js"
    },
    "./fileManager": {
      "types": "./src/fileManager/index.ts",
      "import": "./dist/fileManager.js",
      "require": "./dist/fileManager.cjs",
      "default": "./dist/fileManager.js"
    },
    "./agents": {
      "types": "./src/agents/index.ts",
      "import": "./dist/agents.js",
      "require": "./dist/agents.cjs",
      "default": "./dist/agents.js"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@langchain/core": "^1.1.34",
    "@langchain/langgraph": "^1.2.4",
    "@langchain/openai": "^1.3.0",
    "langchain": "^1.2.35",
    "playwright": "^1.58.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "~5.9.3",
    "vite": "^8.0.0"
  }
}
